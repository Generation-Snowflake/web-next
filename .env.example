# Contact form (app/api/contact/route.ts) — SMTP delivery via Nodemailer.
# Copy to .env.local and fill in. Without these, the form returns a 503 and
# the UI shows the "email us directly" fallback.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where inquiries are delivered:
CONTACT_TO=hello@gsf-robotics.com
# Optional From header (defaults to "GSF Robotics Website <SMTP_USER>"):
CONTACT_FROM=
